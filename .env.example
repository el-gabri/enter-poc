# Copy to .env and fill in. All variables are prefixed LITIGATION_.

# --- LLM provider ---
# "openai" for real calls, "mock" for offline/deterministic mode (tests, demos, CI)
LITIGATION_LLM_PROVIDER=openai
LITIGATION_OPENAI_API_KEY=sk-...
LITIGATION_LLM_MODEL=gpt-4o-mini
LITIGATION_EMBEDDING_MODEL=text-embedding-3-small

# --- Storage ---
LITIGATION_DATA_DIR=./data

# --- Output ---
# Language of the generated report (documents are analyzed in their own language)
LITIGATION_REPORT_LANGUAGE=pt-BR

# --- Logging ---
LITIGATION_LOG_LEVEL=INFO
